# Core AI provider
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-pro
OPENROUTER_REFERER=http://localhost:3000
OPENROUTER_TITLE=Golf Swing Analyzer
COACHING_ANALYSIS_PROVIDER=mock

# Local development defaults
SESSION_REPOSITORY_PROVIDER=local
UPLOAD_STORAGE_PROVIDER=local
ARTIFACT_STORAGE_PROVIDER=local
FFMPEG_PATH=/opt/homebrew/bin/ffmpeg
# MEDIA_ARTIFACT_PROVIDER=ffmpeg

# Optional report defaults
# REPORT_MODE=concise
# MAX_RETAINED_RAW_VIDEOS=10
# RAW_VIDEO_RETENTION_DAYS=14

# Production adapters
# SESSION_REPOSITORY_PROVIDER=neon
# DATABASE_URL=postgres://...
# NEON_DATABASE_URL=postgres://...
# UPLOAD_STORAGE_PROVIDER=s3
# ARTIFACT_STORAGE_PROVIDER=s3
